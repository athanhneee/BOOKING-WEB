PORT=7000
NODE_ENV=development
TRUST_PROXY=0
MYSQLHOST=127.0.0.1
MYSQLPORT=3306
MYSQLDATABASE=booking_room
MYSQLUSER=root
MYSQLPASSWORD=
MYSQL_SSL=false
MYSQL_SSL_CA=./certs/ca.pem
JWT_SECRET_KEY=replace-with-strong-32-byte-minimum-secret
JWT_ACCESS_SECRET=replace-with-strong-32-byte-minimum-access-secret
JWT_REFRESH_SECRET=replace-with-strong-32-byte-minimum-refresh-secret
REFRESH_SECRET=replace-with-strong-32-byte-minimum-refresh-secret
TOKEN_HASH_SECRET=replace-with-strong-32-byte-minimum-token-hash-secret
OTP_HASH_SECRET=replace-with-strong-32-byte-minimum-otp-hash-secret
COOKIE_SECRET=replace-with-strong-32-byte-minimum-cookie-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
OTP_TTL_MINUTES=10
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
CLIENT_ORIGIN=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
REQUEST_BODY_LIMIT=1mb
GLOBAL_RATE_LIMIT_WINDOW_MINUTES=15
GLOBAL_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=30
OTP_HTTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_HTTP_RATE_LIMIT_MAX=3
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MINUTES=15
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
PAYMENT_CALLBACK_RATE_LIMIT_WINDOW_MINUTES=5
PAYMENT_CALLBACK_RATE_LIMIT_MAX=120
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VNPAY_TMN_CODE=your-vnpay-terminal-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:7000/api/payments/vnpay/return
VNPAY_LOCALE=vn
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
REFRESH_TOKEN_COOKIE_NAME=refreshToken
REFRESH_TOKEN_COOKIE_PATH=/api/auth
REFRESH_TOKEN_COOKIE_SAME_SITE=lax
REFRESH_TOKEN_COOKIE_SECURE=false
ALLOW_REFRESH_TOKEN_IN_BODY=true
ALLOW_REFRESH_TOKEN_IN_HEADER=true
AUTH_DEBUG_OTP=false
ALLOW_PRODUCTION_AUTO_SCHEMA_SYNC=false
